{
  "name": "@lvce-editor/source-action-worker-monorepo",
  "version": "0.0.0-dev",
  "license": "MIT",
  "author": "Lvce Editor",
  "type": "module",
  "scripts": {
    "build": "node packages/build/src/build.js",
    "build:static": "node packages/build/src/build-static.js",
    "build:watch": "./packages/build/node_modules/.bin/esbuild --format=esm --bundle --external:node:buffer --external:electron --external:ws --external:node:worker_threads --watch packages/source-action-worker/src/sourceActionWorkerMain.ts --outfile=.tmp/dist/dist/sourceActionWorkerMain.js",
    "dev": "node packages/build/src/dev.js",
    "format": "prettier --write .",
    "postinstall": "lerna bootstrap --ci",
    "lint": "eslint .",
    "measure": "cd packages/memory && npm run measure",
    "test": "lerna run test",
    "type-check": "tsc -b"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 150
  },
  "devDependencies": {
    "@lerna/legacy-package-management": "^8.2.4",
    "@lvce-editor/eslint-config": "^16.4.0",
    "eslint": "^10.7.0",
    "lerna": "^8.2.3",
    "prettier": "^3.7.4",
    "typescript": "^6.0.0"
  }
}
